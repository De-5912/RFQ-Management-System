generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PURCHASE_EXECUTIVE
  PURCHASE_MANAGER
  HOD
  FINANCE
  DEPARTMENT_REQUESTER
  EMPLOYEE
  BUYER_PURCHASE_EXECUTIVE
  REGION_HEAD
  EVALUATION_MANAGER
  INSTALLATION_HOD
  MAINTENANCE_HOD
  MOD_HOD
  ADMIN_HOD
  SAFETY_HOD
  QUALITY_HOD
  SALES_HOD
  PURCHASE_HOD
  HOS
  ADMINISTRATOR
  VENDOR
}

enum UserCategory {
  COMPANY_EMPLOYEE
  VENDOR
}

enum RFQStatus {
  DRAFT
  RFQ_PREPARED
  RFQ_SENT
  QUOTATION_AWAITED
  QUOTATION_RECEIVED
  UNDER_COMPARISON
  NEGOTIATION
  FINAL_VENDOR_SELECTED
  APPROVED
  PO_CREATED
  CLOSED
  CANCELLED
}

enum VendorApprovalStatus {
  APPROVED
  CONDITIONAL
  BLOCKED
  PENDING
}

enum VendorType {
  REGULAR_VENDOR
  OEM
  AUTHORIZED_VENDOR
  CUSTOMIZED_VENDOR
}

enum VendorRegistrationStatus {
  PENDING_VERIFICATION
  APPROVED
  REJECTED
  ACCOUNT_CREATED
}

enum QuotationStatus {
  DRAFT
  SUBMITTED
  LOCKED
  WITHDRAWN
}

enum AvailabilityStatus {
  AVAILABLE
  PARTIALLY_AVAILABLE
  NOT_AVAILABLE
}

enum TechnicalCompliance {
  COMPLIANT
  PARTIAL
  NON_COMPLIANT
  NOT_APPLICABLE
}

enum RFQType {
  NORMAL
  SPECIAL
}

enum RFQApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ComparisonStatus {
  NOT_GENERATED
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum ComparisonApprovalStage {
  RFQ_APPROVAL
  STAGE_1
  STAGE_2
  STAGE_3
  STAGE_4
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AttachmentEntity {
  RFQ
  QUOTATION
  COMPARISON
  APPROVAL
  EMAIL_SCREENSHOT
  PO
  VENDOR
  VENDOR_REGISTRATION
}

enum EmailStatus {
  SENT
  FAILED
  LOGGED_ONLY
}

enum IntegrationStatus {
  NOT_READY
  PENDING
  SENT
  FAILED
  SYNCED
}

enum PasswordResetAudience {
  COMPANY_EMPLOYEE
  VENDOR
}

model RoleDefinition {
  id          String       @id @default(cuid())
  key         String       @unique
  name        String
  category    UserCategory
  description String?
  permissions Json
  isSystem    Boolean      @default(true)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  users User[]
}

model User {
  id                   String          @id @default(cuid())
  name                 String
  email                String          @unique
  passwordHash         String
  role                 Role
  roleKey              String?
  roleDefinition       RoleDefinition? @relation(fields: [roleKey], references: [key])
  category             UserCategory    @default(COMPANY_EMPLOYEE)
  designation          String?
  department           String?
  phone                String?
  vendorId             String?
  vendor               Vendor?         @relation(fields: [vendorId], references: [id])
  mustChangePassword   Boolean         @default(false)
  passwordUpdatedAt    DateTime?
  verifiedCompanyEmail Boolean         @default(false)
  isActive             Boolean         @default(true)
  lastLoginAt          DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  deletedAt            DateTime?

  sessions                    Session[]
  createdRfqs                 RFQ[]                @relation("RFQCreatedBy")
  auditLogs                   AuditLog[]
  approvals                   Approval[]           @relation("ApprovalApprover")
  uploadedFiles               Attachment[]         @relation("AttachmentUploader")
  sentEmails                  EmailLog[]           @relation("EmailSender")
  reportDownloads             ReportDownloadLog[]
  submittedQuotes             Quotation[]          @relation("QuotationSubmittedBy")
  passwordResetTokens         PasswordResetToken[]
  comparisonApprovals         ComparisonApproval[] @relation("ComparisonApprovalApprover")
  verifiedVendorRegistrations VendorRegistration[] @relation("VendorRegistrationVerifier")
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Vendor {
  id                          String               @id @default(cuid())
  vendorCode                  String?              @unique
  companyName                 String
  vendorType                  VendorType           @default(REGULAR_VENDOR)
  contactPerson               String
  email                       String               @unique
  phone                       String
  address                     String
  city                        String?
  state                       String?
  country                     String?
  pinCode                     String?
  gstNumber                   String?
  pan                         String?
  category                    String
  productCategory             String?
  serviceCategory             String?
  approvedStatus              VendorApprovalStatus @default(PENDING)
  pastRating                  Decimal              @default(0) @db.Decimal(4, 2)
  paymentTerms                String?
  leadTimeHistory             String?
  primaryContactName          String?
  primaryContactDesignation   String?
  primaryContactMobile        String?
  primaryContactEmail         String?
  secondaryContactName        String?
  secondaryContactDesignation String?
  secondaryContactMobile      String?
  secondaryContactEmail       String?
  bankDetails                 String?
  verifiedAt                  DateTime?
  verifiedById                String?
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  deletedAt                   DateTime?

  users         User[]
  rfqs          RFQVendor[]
  quotations    Quotation[]
  selectedIn    RFQ[]                @relation("FinalVendor")
  approvals     Approval[]           @relation("ApprovalSelectedVendor")
  emails        EmailLog[]
  attachments   Attachment[]
  registrations VendorRegistration[]
}

model RFQ {
  id                          String            @id @default(cuid())
  rfqNumber                   String            @unique
  rfqDate                     DateTime
  deadline                    DateTime
  department                  String
  requesterName               String
  description                 String
  requiredDeliveryDate        DateTime?
  deliveryLocation            String
  technicalSpecification      String?
  preferredMake               String?
  paymentTerms                String?
  warrantyRequirement         String?
  taxes                       String?
  remarks                     String?
  rfqType                     RFQType           @default(NORMAL)
  rfqApprovalStatus           RFQApprovalStatus @default(PENDING)
  rfqApprovedAt               DateTime?
  rfqApprovedById             String?
  specialVendorJustification  String?
  comparisonStatus            ComparisonStatus  @default(NOT_GENERATED)
  comparisonGeneratedAt       DateTime?
  comparisonRejectedAt        DateTime?
  comparisonRejectionComments String?
  sapReferenceNumber          String?
  integrationStatus           IntegrationStatus @default(NOT_READY)
  status                      RFQStatus         @default(DRAFT)
  createdById                 String
  createdBy                   User              @relation("RFQCreatedBy", fields: [createdById], references: [id])
  finalVendorId               String?
  finalVendor                 Vendor?           @relation("FinalVendor", fields: [finalVendorId], references: [id])
  poNumber                    String?
  poCreatedAt                 DateTime?
  createdAt                   DateTime          @default(now())
  updatedAt                   DateTime          @updatedAt
  deletedAt                   DateTime?

  items               RFQItem[]
  vendors             RFQVendor[]
  quotations          Quotation[]
  attachments         Attachment[]
  approvals           Approval[]
  comparisonApprovals ComparisonApproval[]
  emailLogs           EmailLog[]
}

model RFQItem {
  id                     String   @id @default(cuid())
  rfqId                  String
  rfq                    RFQ      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  lineNumber             Int
  description            String
  partNumber             String?
  quantity               Decimal  @db.Decimal(14, 3)
  uom                    String
  technicalSpecification String?
  preferredMake          String?
  remarks                String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  quotationItems QuotationItem[]

  @@unique([rfqId, lineNumber])
}

model RFQVendor {
  id            String    @id @default(cuid())
  rfqId         String
  rfq           RFQ       @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  vendorId      String
  vendor        Vendor    @relation(fields: [vendorId], references: [id])
  assignedAt    DateTime  @default(now())
  emailSentAt   DateTime?
  viewedAt      DateTime?
  noQuoteReason String?
  notes         String?

  @@unique([rfqId, vendorId])
}

model Quotation {
  id                   String              @id @default(cuid())
  rfqId                String
  rfq                  RFQ                 @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  vendorId             String
  vendor               Vendor              @relation(fields: [vendorId], references: [id])
  submittedById        String?
  submittedBy          User?               @relation("QuotationSubmittedBy", fields: [submittedById], references: [id])
  status               QuotationStatus     @default(DRAFT)
  availability         AvailabilityStatus  @default(AVAILABLE)
  quantityOffered      Decimal?            @db.Decimal(14, 3)
  baseTotal            Decimal             @default(0) @db.Decimal(14, 2)
  taxTotal             Decimal             @default(0) @db.Decimal(14, 2)
  freightCost          Decimal             @default(0) @db.Decimal(14, 2)
  packingCost          Decimal             @default(0) @db.Decimal(14, 2)
  discount             Decimal             @default(0) @db.Decimal(14, 2)
  leadTimeDays         Int?
  paymentTerms         String?
  warranty             String?
  taxCode              String?
  hsn                  String?
  hsc                  String?
  importDuty           Decimal             @default(0) @db.Decimal(14, 2)
  retention            String?
  bankGuarantee        String?
  otherCommercialTerms String?
  validityDate         DateTime?
  technicalCompliance  TechnicalCompliance @default(NOT_APPLICABLE)
  remarks              String?
  submittedAt          DateTime?
  lastEditedAt         DateTime?
  lockedAt             DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  deletedAt            DateTime?

  items       QuotationItem[]
  attachments Attachment[]

  @@unique([rfqId, vendorId])
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  rfqItemId   String?
  rfqItem     RFQItem?  @relation(fields: [rfqItemId], references: [id])
  description String
  quantity    Decimal   @db.Decimal(14, 3)
  unitPrice   Decimal   @db.Decimal(14, 2)
  totalPrice  Decimal   @db.Decimal(14, 2)
  taxAmount   Decimal   @default(0) @db.Decimal(14, 2)
  remarks     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Attachment {
  id                   String              @id @default(cuid())
  fileName             String
  storagePath          String
  mimeType             String
  sizeBytes            Int
  entityType           AttachmentEntity
  rfqId                String?
  rfq                  RFQ?                @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  quotationId          String?
  quotation            Quotation?          @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  approvalId           String?
  approval             Approval?           @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  vendorId             String?
  vendor               Vendor?             @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  vendorRegistrationId String?
  vendorRegistration   VendorRegistration? @relation(fields: [vendorRegistrationId], references: [id], onDelete: Cascade)
  uploadedById         String?
  uploadedBy           User?               @relation("AttachmentUploader", fields: [uploadedById], references: [id])
  createdAt            DateTime            @default(now())
}

model VendorRegistration {
  id                          String                   @id @default(cuid())
  companyName                 String
  address                     String
  city                        String
  state                       String
  country                     String
  pinCode                     String
  primaryContactName          String
  primaryContactDesignation   String?
  primaryContactMobile        String
  primaryContactEmail         String
  secondaryContactName        String?
  secondaryContactDesignation String?
  secondaryContactMobile      String?
  secondaryContactEmail       String?
  gstNumber                   String?
  pan                         String?
  bankDetails                 String?
  productCategory             String?
  serviceCategory             String?
  businessCategory            String?
  status                      VendorRegistrationStatus @default(PENDING_VERIFICATION)
  reviewerComments            String?
  createdVendorId             String?
  createdVendor               Vendor?                  @relation(fields: [createdVendorId], references: [id])
  verifiedById                String?
  verifiedBy                  User?                    @relation("VendorRegistrationVerifier", fields: [verifiedById], references: [id])
  submittedAt                 DateTime                 @default(now())
  verifiedAt                  DateTime?
  updatedAt                   DateTime                 @updatedAt

  attachments Attachment[]
}

model Approval {
  id               String         @id @default(cuid())
  rfqId            String
  rfq              RFQ            @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  approverId       String
  approver         User           @relation("ApprovalApprover", fields: [approverId], references: [id])
  selectedVendorId String?
  selectedVendor   Vendor?        @relation("ApprovalSelectedVendor", fields: [selectedVendorId], references: [id])
  status           ApprovalStatus @default(PENDING)
  comments         String?
  decidedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  attachments Attachment[]
}

model ComparisonApproval {
  id              String                  @id @default(cuid())
  rfqId           String
  rfq             RFQ                     @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  stage           ComparisonApprovalStage
  approverRoleKey String?
  approverRole    Role?
  approverId      String?
  approver        User?                   @relation("ComparisonApprovalApprover", fields: [approverId], references: [id])
  status          ApprovalStatus          @default(PENDING)
  comments        String?
  decidedAt       DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@unique([rfqId, stage])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  userRole   Role?
  action     String
  entityType String
  entityId   String
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  details    String?
  createdAt  DateTime @default(now())
}

model PasswordResetToken {
  id        String                @id @default(cuid())
  userId    String
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  audience  PasswordResetAudience
  tokenHash String                @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime              @default(now())
}

model EmailLog {
  id                String      @id @default(cuid())
  rfqId             String
  rfq               RFQ         @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  vendorId          String
  vendor            Vendor      @relation(fields: [vendorId], references: [id])
  toEmail           String
  subject           String
  body              String
  status            EmailStatus
  providerMessageId String?
  error             String?
  sentById          String?
  sentBy            User?       @relation("EmailSender", fields: [sentById], references: [id])
  sentAt            DateTime    @default(now())
}

model ReportDownloadLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  reportType String
  filters    Json?
  createdAt  DateTime @default(now())
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String?  @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ItemServiceCatalog {
  id         String   @id @default(cuid())
  name       String   @unique
  category   String?
  defaultUom String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
